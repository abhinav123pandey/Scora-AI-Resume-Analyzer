# Copy this file to .env and fill in your values

# MongoDB connection string (get from MongoDB Atlas or local MongoDB)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-resume-analyzer

# JWT secret — any random long string (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL (for CORS — change to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Port the backend server runs on
PORT=5000

# OpenAI API key (optional — get from platform.openai.com)
# If blank, the app uses smart fallback suggestions instead of real AI
OPENAI_API_KEY=sk-...your-key-here
